{
  "name": "mtools",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:exports": "node scripts/generate-exports.cjs",
    "rebuild:native": "node scripts/rebuild-native.cjs",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "antd": "^6.1.3",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.7.2",
    "konva": "^10.3.0",
    "node-addon-api": "^8.5.0",
    "onnxruntime-node": "^1.26.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.5",
    "react-router-dom": "^7.17.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^39.2.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-glob": "^3.3.3",
    "globals": "^16.5.0",
    "less": "^4.5.1",
    "node-gyp": "^12.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-builder": "^0.1.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "build": {
    "appId": "com.mtools.app",
    "productName": "MTools",
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": ["*.onnx"]
      }
    ],
    "asarUnpack": [
      "node_modules/sharp/**",
      "node_modules/onnxruntime-node/**"
    ]
  }
}
